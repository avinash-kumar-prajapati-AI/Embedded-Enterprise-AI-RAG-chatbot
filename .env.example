# Postgres (Supabase) — pgvector extension must be enabled on this database
DATABASE_URL=postgresql://postgres:password@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Redis (Upstash) — REST API credentials, used for rate limiting
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Master key for encrypting per-tenant provider API keys at rest (Phase 4).
# Generate with: openssl rand -base64 32
MASTER_ENCRYPTION_KEY=

# NextAuth (dashboard auth, Phase 2)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# The only dashboard login: a single long secret only the admin knows — no
# public signup. Treat like a master password. Generate with:
# node -e "console.log(require('crypto').randomBytes(150).toString('base64url'))"
ADMIN_LOGIN_ID=

# Blob storage for uploaded documents (Phase 3) — S3-compatible (e.g. Cloudflare R2)
BLOB_STORAGE_ENDPOINT=
BLOB_STORAGE_ACCESS_KEY_ID=
BLOB_STORAGE_SECRET_ACCESS_KEY=
BLOB_STORAGE_BUCKET=

# Optional: OpenAI moderation endpoint key, used pre-LLM in Phase 6 safety middleware
OPENAI_API_KEY=

# Public homepage demo (Phase 7): a single fixed tenant used for the "try it
# live" widget. DEMO_ADMIN_TOKEN gates /admin/<token>/documents — the only
# way to manage the demo tenant's documents, no login required.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
DEMO_ADMIN_TOKEN=
DEMO_SITE_KEY=
